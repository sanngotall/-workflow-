# 端端通生产环境变量模板
# 使用前复制为 gateway.env 并填入真实值：cp gateway.env.example gateway.env

# 数据库（密码必须修改，不要使用示例值）
DB_DATABASE=ddt_gateway
DB_USERNAME=postgres
DB_PASSWORD=请修改为强密码

# JWT 密钥（必须修改，建议生成 64 位随机字符串）
JWT_SECRET=请修改为64位随机字符串
JWT_EXPIRES_IN=7200s
JWT_REFRESH_EXPIRES_IN=604800s

# AES-256-GCM 加密密钥（必须修改）
# AES_KEY: 32 字节（64 位 hex），AES_IV: 16 字节（32 位 hex）
AES_KEY=请修改为64位hex密钥
AES_IV=请修改为32位hex向量

# 限流配置
RATE_LIMIT_PER_MINUTE=60
MAX_QUEUE_SIZE=10000

# 登录失败保护
LOGIN_FAIL_THRESHOLD=5
LOGIN_FAIL_BAN_SEC=900
