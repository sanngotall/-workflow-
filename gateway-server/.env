PORT=13000
NODE_ENV=development

# 数据库（本机 Docker 容器 ddt-postgres-dev，对齐 docker-compose.dev.yml）
DB_HOST=localhost
DB_PORT=15432
DB_USERNAME=postgres
DB_PASSWORD=PTahvdWeD5-4WRtQms6BJw
DB_DATABASE=ddt_gateway

# Redis（本机 Docker 容器 ddt-redis-dev，对齐 docker-compose.dev.yml）
REDIS_HOST=localhost
REDIS_PORT=16379

# JWT（开发环境用，生产环境需替换）
# access_token 过期 2h，refresh_token 过期 7d（对齐 SPEC-05 §4.1）
JWT_SECRET=ddt_dev_jwt_secret_2026_please_change_in_production_32bytes
JWT_EXPIRES_IN=7200s
JWT_REFRESH_EXPIRES_IN=604800s

# 初始 admin 账户配置（对齐 SPEC-05 §9）
# 首次启动随机生成密码，写入 INIT_ADMIN_PASSWORD_FILE 指定文件
INIT_ADMIN_EMAIL=admin@ddt.local
INIT_ADMIN_PASSWORD_FILE=./.ddt-admin-password

# bcrypt 哈希成本（默认 12，对齐 SPEC-05 §8）
BCRYPT_COST=12

# 登录失败限流（对齐 SPEC-05 §8）
LOGIN_FAIL_WINDOW_SEC=300
LOGIN_FAIL_THRESHOLD=5
LOGIN_FAIL_BAN_SEC=900

# AES-256-GCM 加密密钥（64 hex 字符 = 32 字节，用于凭证加密）
AES_KEY=7377de9732297ca8de5e0479e0596c4ded719a6b3b0c60a92e35f018c28e941a
AES_IV=e057f51ba05e611bea1bf85cf13eadf2

# 业务数据 TTL 扫描间隔（毫秒），默认 60s
BIZ_TTL_SCAN_INTERVAL_MS=60000

MAX_QUEUE_SIZE=10000
RATE_LIMIT_PER_MINUTE=60

LOG_LEVEL=info
