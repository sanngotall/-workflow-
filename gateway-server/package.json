{
  "name": "ddt-gateway-server",
  "version": "1.0.0",
  "description": "DDT (端端通) Gateway Server - API Gateway & Request Translation Middleware",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "typeorm": "typeorm-ts-node-commonjs",
    "migrate:generate": "npm run typeorm migration:generate -- -d src/database/data-source.ts",
    "migrate:run": "npm run typeorm migration:run -- -d src/database/data-source.ts",
    "migrate:revert": "npm run typeorm migration:revert -- -d src/database/data-source.ts"
  },
  "dependencies": {
    "@fastify/multipart": "^8.3.1",
    "@nestjs/bull": "^10.1.1",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "10.0.3",
    "@nestjs/platform-fastify": "^10.3.0",
    "@nestjs/typeorm": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "axios": "^1.6.5",
    "bcrypt": "^6.0.0",
    "bull": "^4.12.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.3.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "uuid": "^9.0.1",
    "vm2": "^3.9.19"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@types/bull": "^3.15.9",
    "@types/ioredis": "^4.28.10",
    "@types/node": "^20.11.0",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^9.0.8",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
